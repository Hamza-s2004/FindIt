<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarSearch"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1565C0"
        app:title="Search &amp; Filter"
        app:titleTextColor="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Bar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Search by name, category..."
                android:textColor="#212121"
                android:textColorHint="#9E9E9E"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <!-- L9: Filter by Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter by Type"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <RadioGroup
                android:id="@+id/rgFilterType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbAll"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All"
                    android:textColor="#212121"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbFilterLost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lost"
                    android:textColor="#212121"/>

                <RadioButton
                    android:id="@+id/rbFilterFound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Found"
                    android:textColor="#212121"/>

            </RadioGroup>

            <!-- L10: Category Tag Cloud using ConstraintLayout Flow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter by Category"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <!-- Flow helper — wraps tags automatically -->
                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flow_wrapMode="chain"
                    app:flow_horizontalGap="8dp"
                    app:flow_verticalGap="8dp"
                    app:constraint_referenced_ids="tagIdCard,tagWallet,tagElectronics,tagBooks,tagBags,tagKeys,tagOthers"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Tag 1 -->
                <TextView
                    android:id="@+id/tagIdCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🆔 ID Card"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 2 -->
                <TextView
                    android:id="@+id/tagWallet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 Wallet"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 3 -->
                <TextView
                    android:id="@+id/tagElectronics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Electronics"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 4 -->
                <TextView
                    android:id="@+id/tagBooks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Books"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 5 -->
                <TextView
                    android:id="@+id/tagBags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎒 Bags"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 6 -->
                <TextView
                    android:id="@+id/tagKeys"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 Keys"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

                <!-- Tag 7 -->
                <TextView
                    android:id="@+id/tagOthers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 Others"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="@drawable/bg_tag"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Date Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filter by Date"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etFromDate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:hint="From date"
                    android:textColor="#212121"
                    android:textColorHint="#9E9E9E"
                    android:textSize="13sp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="date"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etToDate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:hint="To date"
                    android:textColor="#212121"
                    android:textColorHint="#9E9E9E"
                    android:textSize="13sp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="date"/>

            </LinearLayout>

            <!-- Apply Button -->
            <TextView
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Apply Filters"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_category_featured"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_footer"/>

</LinearLayout>