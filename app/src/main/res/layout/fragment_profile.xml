<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:id="@+id/profileLayout"
    >

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarProfile"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1565C0"
        app:title="My Profile"
        app:titleTextColor="#FFFFFF"/>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- L2: ConstraintLayout Profile Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/profileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Guideline at 35% from left -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.35"/>

                <!-- Avatar -->
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:text="A"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_avatar"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineLeft"/>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Ahmed Ali"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvEmail"
                    app:layout_constraintStart_toEndOf="@id/guidelineLeft"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Email -->
                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="f231234@cfd.nu.edu.pk"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvName"
                    app:layout_constraintBottom_toTopOf="@id/tvRollNo"
                    app:layout_constraintStart_toEndOf="@id/guidelineLeft"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Barrier -->
                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/barrier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="tvName,tvEmail"/>

                <!-- Roll Number -->
                <TextView
                    android:id="@+id/tvRollNo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Roll No: 23F-1234"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/barrier"
                    app:layout_constraintBottom_toTopOf="@id/tvDept"
                    app:layout_constraintStart_toEndOf="@id/guidelineLeft"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Department -->
                <TextView
                    android:id="@+id/tvDept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="CS — FAST NU CFD"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvRollNo"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/guidelineLeft"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Contact Info Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Info"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <!-- Email Row -->
            <RelativeLayout
                android:id="@+id/rowEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/labelEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧 Email"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/valueEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="f231234@cfd.nu.edu.pk"
                    android:textColor="#212121"
                    android:textSize="12sp"
                    android:layout_centerVertical="true"
                    android:layout_toRightOf="@id/labelEmail"
                    android:layout_alignParentEnd="true"
                    android:gravity="end"/>

            </RelativeLayout>

            <!-- Phone Row -->
            <RelativeLayout
                android:id="@+id/rowPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/labelPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Phone"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/valuePhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0300-1234567"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <!-- Location Row -->
            <RelativeLayout
                android:id="@+id/rowLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Location"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/valueLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiniot-Faisalabad Campus"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <!-- Settings Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <!-- Notifications Toggle -->
            <RelativeLayout
                android:id="@+id/rowNotifications"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/labelNotif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔 Notifications"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>

                <Switch
                    android:id="@+id/switchNotif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <!-- Dark Mode Toggle -->
            <RelativeLayout
                android:id="@+id/rowDarkMode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/labelDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 Dark Mode"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>

                <Switch
                    android:id="@+id/switchDark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <!-- Logout Button -->
            <TextView
                android:id="@+id/tvLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Logout"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_logout_btn"/>

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <include layout="@layout/layout_footer"/>

</LinearLayout>