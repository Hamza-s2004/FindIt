<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/postItemLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPost"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1565C0"
        app:title="Post Item"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etItemName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. Blue Wallet, Student ID Card"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="Describe the item in detail..."
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="12dp"/>

            <!-- L9: Lost or Found RadioGroup -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post Type"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <RadioGroup
                android:id="@+id/rgPostType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rbLost"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lost"
                    android:textColor="#212121"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbFound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Found"
                    android:textColor="#212121"/>

            </RadioGroup>

            <!-- L9: Category RadioGroup -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <RadioGroup
                android:id="@+id/rgCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rbIdCard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🆔 ID Card"
                    android:textColor="#212121"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbWallet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 Wallet"
                    android:textColor="#212121"/>

                <RadioButton
                    android:id="@+id/rbElectronics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Electronics"
                    android:textColor="#212121"/>

                <RadioButton
                    android:id="@+id/rbBooks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Books"
                    android:textColor="#212121"/>

                <RadioButton
                    android:id="@+id/rbBags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎒 Bags"
                    android:textColor="#212121"/>

            </RadioGroup>

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. Library, Cafeteria, Parking"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <!-- Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. 07/03/2026"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="date"
                android:layout_marginBottom="12dp"/>

            <!-- Contact -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Number"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etContact"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. 0300-1234567"
                android:textSize="13sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="phone"
                android:layout_marginBottom="20dp"/>

            <!-- Submit Button -->
            <TextView
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Submit Post"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_category_featured"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <include layout="@layout/layout_footer"/>

</LinearLayout>