<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notificationsLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarNotifications"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1565C0"
        app:title="Notifications"
        app:titleTextColor="#FFFFFF"/>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Notifications"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="12dp"/>

            <!-- L7: TableLayout — stretchColumns makes columns fill width -->
            <TableLayout
                android:id="@+id/tableNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="0, 1, 2, 3"
                android:shrinkColumns="0"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="16dp">

                <!-- Header Row -->
                <TableRow
                    android:background="#1565C0"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Item"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:padding="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Type"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:padding="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Location"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:padding="8dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Date"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 1 -->
                <TableRow
                    android:background="#FFFFFF"
                    android:padding="8dp">

                    <TextView
                        android:text="🔑 Keys"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Lost"
                        android:textSize="12sp"
                        android:textColor="#F44336"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Cafeteria"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Today"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 2 -->
                <TableRow
                    android:background="#F5F7FA"
                    android:padding="8dp">

                    <TextView
                        android:text="💳 Wallet"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Found"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Library"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="06/03"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 3 -->
                <TableRow
                    android:background="#FFFFFF"
                    android:padding="8dp">

                    <TextView
                        android:text="📱 Phone"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Lost"
                        android:textSize="12sp"
                        android:textColor="#F44336"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Parking"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="05/03"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 4 -->
                <TableRow
                    android:background="#F5F7FA"
                    android:padding="8dp">

                    <TextView
                        android:text="📚 Books"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Found"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:padding="8dp"/>

                    <TextView
                        android:text="FSM-Building"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="04/03"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 5 -->
                <TableRow
                    android:background="#FFFFFF"
                    android:padding="8dp">

                    <TextView
                        android:text="🎒 Bag"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Lost"
                        android:textSize="12sp"
                        android:textColor="#F44336"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Main Gate"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="03/03"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Row 6 -->
                <TableRow
                    android:background="#F5F7FA"
                    android:padding="8dp">

                    <TextView
                        android:text="🆔 ID Card"
                        android:textSize="12sp"
                        android:textColor="#212121"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Found"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:padding="8dp"/>

                    <TextView
                        android:text="Dhabba"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                    <TextView
                        android:text="02/03"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:padding="8dp"/>

                </TableRow>

            </TableLayout>
        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <include layout="@layout/layout_footer"/>

</LinearLayout>